{
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "env": {
    "FLASK_APP": "app.py",
    "FLASK_ENV": "production",
    "FLASK_DEBUG": "false",
    "SESSION_COOKIE_SECURE": "true",
    "SESSION_COOKIE_SAMESITE": "Lax"
  },
  "functions": {
    "app.py": {
      "maxDuration": 30
    }
  }
}