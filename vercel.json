{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/app.py"
    }
  ],
  "env": {
    "FLASK_APP": "app.py",
    "FLASK_ENV": "production",
    "FLASK_DEBUG": "false",
    "SESSION_COOKIE_SECURE": "true",
    "SESSION_COOKIE_SAMESITE": "Lax"
  },
  "functions": {
    "app.py": {
      "maxDuration": 30,
      "memory": 1024
    }
  }
}