# MatchPredict 环境变量配置示例
# 复制此文件为 .env.local 并填入实际值

# ============================================
# 🔐 必需的安全配置
# ============================================

# Flask 会话加密密钥
# 生成方式：python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here-generate-a-random-one

# ============================================
# 🤖 可选的 AI 功能配置
# ============================================

# Google Gemini API 密钥
# 获取地址：https://ai.google.dev
# 如不配置，AI 功能将不可用
GEMINI_API_KEY=sk-proj-your-gemini-api-key-here

# Gemini 模型名称
# 推荐：gemini-2.0-flash-exp 或 gemini-2.5-flash-lite-preview-06-17
GEMINI_MODEL=gemini-2.0-flash-exp

# ============================================
# 💾 可选的数据库配置
# ============================================

# PostgreSQL 数据库连接字符串
# 格式：postgresql://username:password@hostname:port/database_name
# 示例：postgresql://user:pass123@db.example.com:5432/matchpredict
# 如不配置，将使用内存存储
DATABASE_URL=postgresql://user:password@localhost:5432/matchpredict

# ============================================
# 🍪 Session 和 Cookie 配置
# ============================================

# Cookie 的 SameSite 属性
# 可选值：Strict, Lax, None
# 默认：None（支持跨域请求）
SESSION_COOKIE_SAMESITE=None

# Cookie 域名（跨子域共享时使用）
# 示例：.match-predict.vercel.app（注意开头的点）
# 留空表示使用当前请求的域名
SESSION_COOKIE_DOMAIN=

# ============================================
# 📊 可选的日志和调试配置
# ============================================

# 日志级别
# 可选值：DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Flask 调试模式
# 注意：生产环境必须设为 False
FLASK_DEBUG=False

# ============================================
# 🌐 部署平台特定配置
# ============================================

# Vercel 环境
# Vercel 会自动设置，无需手动配置
# VERCEL=1
# VERCEL_ENV=production
# VERCEL_URL=your-domain.vercel.app

# ============================================
# 📝 配置说明
# ============================================

# 本地开发：
# 1. 复制此文件为 .env.local
# 2. 在 .env.local 中填入你的实际值
# 3. Flask 会自动加载 .env.local

# Vercel 部署：
# 1. 在 Vercel 项目的 Settings → Environment Variables 中配置
# 2. 只需配置必需变量，可选变量可留空
# 3. 配置后点击 Redeploy 重新部署

# ============================================
# 🔑 生成安全密钥
# ============================================

# Python:
# python3 -c "import secrets; print(secrets.token_hex(32))"

# OpenSSL:
# openssl rand -hex 32

# Online:
# https://randomkeygen.com/
